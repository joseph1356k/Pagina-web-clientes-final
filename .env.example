# Copia este archivo como `.env.local` y rellena los valores.
# `.env.local` está gitignored: nunca subas secretos al repo.

# Supabase — claves PÚBLICAS (seguras para el navegador)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Dominio del sitio (canonical/OG/metadataBase). Producción: https://itsmiracleai.com.co
NEXT_PUBLIC_SITE_URL=http://localhost:3100

# Backend clínico (motor Miracle) — plantillas, encounters y generación de notas.
# El frontend le habla SOLO a este API (con el token Supabase del usuario);
# nunca directo a Supabase para las tablas clínicas ni con service-role key.
# Local: http://localhost:3000 · Producción: URL del deployment del backend.
# OJO: el backend debe incluir el origen del frontend en su ALLOWED_ORIGINS.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# API key de plataforma del backend Miracle (SECRETA, solo servidor: nunca con
# prefijo NEXT_PUBLIC_). La usa /api/stt/session para pedir las credenciales
# temporales de transcripción en vivo. Formato: miracle_...
MIRACLE_API_KEY=

# Nota: CREAR cuentas (super-admin / admin → "Agregar médico") NO necesita la
# service-role key — se hace con la función SECURITY DEFINER create_org_member.
# No hay que configurar nada extra en el servidor ni en Vercel.

# IA de VISIÓN (lectura de fotos) — SECRETA, solo servidor (nunca NEXT_PUBLIC_).
# Es la MISMA key para las dos funciones que leen imágenes:
#   · /api/parse-schedule          → importar la agenda del día desde una foto.
#   · /api/clinical/note-from-photo → informe de patología desde la foto de la hoja
#                                     manuscrita (solo cuentas patólogo).
# Sin ella NADA se rompe: ambas pantallas degradan a "rellenar a mano". Por eso, si
# falta en Vercel, la feature de patología queda desplegada pero inútil.
# REQUERIDA en Vercel (proyecto miracle-web, scope Production) para que la foto funcione.
# Ver docs/pendiente-patologia-api-key.md
ANTHROPIC_API_KEY=
# Opcional; por defecto claude-sonnet-4-6.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Nota: la generación de notas clínicas desde AUDIO no usa esta key: la hace el
# backend Miracle (NEXT_PUBLIC_API_BASE_URL).

# Observabilidad (opcional) — reporte de errores con Sentry.
# Los archivos ya están cableados (instrumentation*.ts, next.config.ts): SIN
# esta variable todo es no-op y el build es idéntico al de hoy. Para activarlo,
# crea el proyecto en Sentry y pega su DSN aquí (y en Vercel, entorno Production).
# NEXT_PUBLIC_SENTRY_DSN=https://xxxx@oyyyy.ingest.sentry.io/zzzz
